{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "gateway/**/*.js",
    "auth-service/**/*.js",
    "user-service/**/*.js",
    "product-service/**/*.js",
    "notification-service/**/*.js"
  ],
  "exclude": [
    "**/node_modules/**",
    "user-service/prisma/**"
  ]
}
